# ============================================================
# Retro Closet — environment variable template
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env        (macOS/Linux)
#   Copy-Item .env.example .env (PowerShell)
#
# `.env` is gitignored — NEVER commit real secrets.
# In production these are set in the Netlify dashboard
# (Site settings → Environment variables), not from this file.
# `.env` is only loaded locally when you run `netlify dev`.
# ============================================================

# ── Airtable (REQUIRED — used today) ────────────────────────
# Personal access token (starts with "pat...").
# Needs scopes:  data.records:read  +  data.records:write
# Grant it access to the base below.
# Create one at: https://airtable.com/create/tokens
# Used by: netlify/functions/get-products.js, netlify/functions/place-order.js
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Airtable IDs (hardcoded in code — listed here for reference) ──
# These are NOT read from the environment; the functions hardcode
# them as constants (BASE_ID / TABLE_ID / ORDERS_TABLE_ID at the top
# of place-order.js and get-products.js). Listed here so you know
# what they are. Base/table IDs are not secret.
#
#   Products base : appcA2sFnpO4O9x7N
#   Products table: tblWjg7NqsZvK0otW
#   Orders table  : tbl7mY2r8TUhWBVgE   (checkout writes one row per order)
#
# AIRTABLE_BASE_ID=appcA2sFnpO4O9x7N
# AIRTABLE_PRODUCTS_TABLE_ID=tblWjg7NqsZvK0otW
# AIRTABLE_ORDERS_TABLE_ID=tbl7mY2r8TUhWBVgE
